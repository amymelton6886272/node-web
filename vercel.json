{
  "buildCommand": "npm run build",
  "outputDirectory": "deploy-build",
  "rewrites": [
    {
      "source": "/((?!assets/|sitemap\\.xml|robots\\.txt|ads\\.txt|favicon\\.svg|google0ae2f1634fecb56d\\.html).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ]
}
