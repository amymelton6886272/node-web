{
  "buildCommand": "npm run build",
  "outputDirectory": "deploy-build",
  "functions": {
    "api/iap.js": {
      "maxDuration": 10
    },
    "api/iap-detail.js": {
      "maxDuration": 10
    },
    "api/iap-compare.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/ip",
      "destination": "/price",
      "permanent": true
    },
    {
      "source": "/ip/",
      "destination": "/price",
      "permanent": true
    },
    {
      "source": "/address",
      "destination": "/price",
      "permanent": true
    },
    {
      "source": "/address/",
      "destination": "/price",
      "permanent": true
    }
  ]
}
