{
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "dev:hmr": "astro dev --host 0.0.0.0",
    "sync:assets": "node scripts/sync-public-assets.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "prebuild": "npm run sync:assets && npm run sitemap",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "npm run build && cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "preview:only": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "start": "npm run preview"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "astro": "^5.13.0",
    "cross-env": "^10.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
