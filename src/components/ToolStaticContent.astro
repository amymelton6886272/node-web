---
/**
 * Server-rendered publisher content for tool pages.
 * variant:
 *  - intro: compact title/lead above the interactive tool
 *  - full:  detailed guide below the tool (AdSense + humans)
 *  - all:   legacy full block (intro + details + howto)
 */
import { toolContent } from '../data/toolContent.js';

const { tool, variant = 'all' } = Astro.props;
const en = toolContent.en?.[tool];
const zh = toolContent.zh?.[tool];

function normalizeLinks(links = []) {
  return links.map((link) => {
    const href = (link.href || '').replace(/^#/, '/');
    return { ...link, href: href === '/' ? '/' : href };
  });
}

const enLinks = normalizeLinks(en?.links || []);
const zhLinks = normalizeLinks(zh?.links || []);
const showIntro = variant === 'intro' || variant === 'all';
const showDetails = variant === 'full' || variant === 'all';
const showHowto = variant === 'full' || variant === 'all';
---

{(en || zh) && showIntro && (
  <section class="card toolIntroStrip" aria-label="Tool overview">
    {en && (
      <div class="lang-en">
        {en.title && <h1 class="toolIntroTitle">{en.title}</h1>}
        {en.intro && <p class="contentLead toolIntroLead">{en.intro}</p>}
        <div class="toolIntroActions">
          <a class="toolJumpBtn" href="#tool-workspace">Use the tool</a>
          {showDetails === false && (
            <a class="toolJumpLink" href="#tool-guide">Read full guide</a>
          )}
          {enLinks.slice(0, 3).map((link) => <a class="toolJumpLink" href={link.href}>{link.label}</a>)}
        </div>
      </div>
    )}
    {zh && (
      <div class="lang-zh" lang="zh-CN">
        {zh.title && <h1 class="toolIntroTitle">{zh.title}</h1>}
        {zh.intro && <p class="contentLead toolIntroLead">{zh.intro}</p>}
        <div class="toolIntroActions">
          <a class="toolJumpBtn" href="#tool-workspace">开始使用工具</a>
          {showDetails === false && (
            <a class="toolJumpLink" href="#tool-guide">阅读完整说明</a>
          )}
          {zhLinks.slice(0, 3).map((link) => <a class="toolJumpLink" href={link.href}>{link.label}</a>)}
        </div>
      </div>
    )}
  </section>
)}

{(en || zh) && showDetails && (
  <section id="tool-guide" class="contentSection card toolStaticContent" aria-label="Publisher content">
    {en && (
      <div class="lang-en">
        {variant === 'full' && en.title && <h2>{en.title}</h2>}
        {variant === 'full' && en.intro && <p class="contentLead">{en.intro}</p>}
        {en.items?.length > 0 && (
          <div class="contentGrid">
            {en.items.map((item) => (
              <article class="contentBlock">
                <h3>{item.heading}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        )}
        {en.note && <p class="contentNote">{en.note}</p>}
        {enLinks.length > 0 && (
          <div class="contentLinks">
            <span>{en.linksLabel || 'Related reading'}</span>
            {enLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          </div>
        )}
      </div>
    )}

    {zh && (
      <div class="lang-zh" lang="zh-CN">
        {variant === 'full' && zh.title && <h2>{zh.title}</h2>}
        {variant === 'full' && zh.intro && <p class="contentLead">{zh.intro}</p>}
        {zh.items?.length > 0 && (
          <div class="contentGrid">
            {zh.items.map((item) => (
              <article class="contentBlock">
                <h3>{item.heading}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        )}
        {zh.note && <p class="contentNote">{zh.note}</p>}
        {zhLinks.length > 0 && (
          <div class="contentLinks">
            <span>{zh.linksLabel || '相关阅读'}</span>
            {zhLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          </div>
        )}
      </div>
    )}
  </section>
)}

{showHowto && (
  <section class="card toolReviewNotes" aria-label="How to use this page">
    <div class="lang-en">
      <h2>How to use this page safely</h2>
      <ol class="workflowList" style="list-style:decimal;padding-left:1.2rem;display:grid;gap:.75rem;">
        <li>
          <strong>Skim the overview, then run the tool.</strong>
          <p>Use the interactive section for the task at hand, then come back to the detailed guide if the result looks incomplete or high-stakes.</p>
        </li>
        <li>
          <strong>Treat partial API data as a clue, not a final answer.</strong>
          <p>Empty results, delayed feeds, or region mismatches can happen. Re-check the App Store, Apple ID settings, or the original source before you act.</p>
        </li>
        <li>
          <strong>Verify prices, trials, refunds, and permissions officially.</strong>
          <p>Storewise helps you research faster. Billing and account outcomes still depend on Apple’s screens and policies.</p>
        </li>
        <li>
          <strong>Open related checklists for expensive or hard-to-reverse decisions.</strong>
          <p>Paid apps, free trials, family devices, and region switching are safer with a short written checklist.</p>
        </li>
      </ol>
    </div>
    <div class="lang-zh" lang="zh-CN">
      <h2>如何安全使用本页</h2>
      <ol class="workflowList" style="list-style:decimal;padding-left:1.2rem;display:grid;gap:.75rem;">
        <li>
          <strong>先看短说明，再直接使用工具。</strong>
          <p>交互区用于完成当前任务；如果结果不完整或决策成本高，再回到下方详细说明。</p>
        </li>
        <li>
          <strong>把不完整接口数据当线索，不要当最终结论。</strong>
          <p>空结果、延迟数据或地区差异都可能出现。行动前请回到 App Store、Apple ID 设置或原始来源核对。</p>
        </li>
        <li>
          <strong>价格、试用、退款和权限以官方界面为准。</strong>
          <p>Storewise 用于加速研究；扣费与账号结果仍取决于 Apple 页面与规则。</p>
        </li>
        <li>
          <strong>高成本或难撤销的决策，配合清单使用。</strong>
          <p>付费应用、免费试用、家庭设备和切区前，建议先过一遍对应清单。</p>
        </li>
      </ol>
    </div>
  </section>
)}
