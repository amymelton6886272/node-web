about: {
title: 'About',
sub: 'Wolffy is a lightweight utility hub for App Store lookups, network checks, address generation, and practical Apple ecosystem guides.',
whatTitle: 'What Wolffy Does',
whatDesc: 'Wolffy brings common small tools into one clean place: App Store free app discovery, cross-region price comparison, IAP lookup, high-resolution icon lookup, current IP/connectivity checks, local address generation, proxy config navigation, and a shortcut to the GitHub/Docker acceleration hub. Each tool is designed to minimize redirects, reduce distractions, and make frequent actions fast to perform.',
whyTitle: 'Why Wolffy Exists',
whyDesc: 'App Store research often involves bouncing between multiple sites, regions, and tools. Price differences between regions can be significant but hard to discover. App privacy details are buried in lengthy pages. Finding high-resolution icons requires manual URL manipulation. Wolffy consolidates these workflows into a single, fast, privacy-respecting interface. We believe useful information should be easy to access, not hidden behind logins, ads, or complicated navigation.',
dataTitle: 'Where Data Comes From',
dataDesc: 'Pages use public and user-accessible sources such as Apple iTunes Search / Lookup APIs, App Store product pages, public IP geolocation APIs, community-curated free app feeds, public proxy configuration repositories, and browser-local generated data. Third-party data may be delayed, incomplete, region-specific, or temporarily unavailable. Results are displayed as-is from their sources — Wolffy does not modify or guarantee the accuracy of third-party information.',
designTitle: 'Design Principles',
designDesc: 'Lightweight, clear, and low-friction. Every feature is designed to avoid unnecessary logins and redirects, keep sensitive data out of the page, support both light and dark themes, include both Chinese and English interfaces, and make frequent actions fast to copy, open, save, or export. No account registration is required for any feature. No tracking scripts beyond what the hosting platform requires.',
usageTitle: 'Usage Notes',
usageDesc: 'This is an information aggregation and utility site, not an official Apple, GitHub, Docker, or third-party service. Generated addresses are for testing and form-filling convenience only. Verify external data yourself and follow local laws, platform rules, and service terms.',
contactTG: 'Contact TG Bot:',
disclaimer: 'Disclaimer',
privacy: 'Privacy Policy',
},
disclaimer: {
title: 'Disclaimer',
sub: 'Use this site in compliance with laws, copyright, and platform rules.',
s1Title: '1. Information sources',
s1Desc: 'Content comes from public web pages, public APIs, or user-accessible data sources, for info aggregation, learning, and front-end demo only. No guarantee of completeness, accuracy, timeliness, or availability.',
s2Title: '2. User responsibility',
s2Desc: 'Users should judge applicability and comply with local laws, Apple App Store rules, service terms, and config author requirements. All risks from using this site are borne by the user.',
s3Title: '3. Accounts and sensitive info',
s3Desc: 'This site does not encourage or assist unauthorized account use, sharing, trading, or bypassing access restrictions. Sensitive fields are protected by default; password copy is disabled.',
s4Title: '4. External links',
s4Desc: 'This site may link to third-party sites or the App Store. Third-party content, privacy, security, and availability are their responsibility.',
s5Title: '5. Content removal',
s5Desc: 'If you believe displayed info infringes your rights, or you do not want public info aggregated here, contact the site maintainer for review.',
},
privacy: {
title: 'Privacy Policy',
sub: 'This site collects minimal data, only what page functionality requires.',
s1Title: '1. What we collect',
s1Desc: 'The current version is a front-end demo. Beyond browser-generated requests for pages and third-party APIs, this site does not request personal info like name, phone, ID, or payment details.',
s2Title: '2. Local data',
s2Desc: 'Theme preferences, copy prompts, and filter states are for page experience only, stored in browser session or page memory. Not used for profiling.',
s3Title: '3. Third-party APIs',
s3Desc: 'Features like free apps, configs, and App Store links may call third-party APIs. Your browser visiting these resources may cause the third party to log IP, User-Agent, and access time per their policies.',
s4Title: '4. Cookies and tracking',
s4Desc: 'This site does not set ad-tracking cookies. If analytics, login, or cloud features are added, usage will be clearly disclosed with opt-out options.',
s5Title: '5. Data security',
s5Desc: 'This site does not store passwords or sensitive info. Do not enter private accounts, passwords, verification codes, or keys in search boxes or feedback forms.',
s6Title: '6. Policy updates',
s6Desc: 'Privacy policy may change with features. Updates will be shown on the page. Continued use means you accept the updated policy.',
},
accounts: {
title: 'Shared Apple ID Accounts',
sub: 'Real-time sync · Status monitoring · Quick copy',
accountLabel: 'Account',
email: 'Email',
password: 'Password',
copy: 'Copy',
protected: 'Protected',
available: '✅ Available',
maintenance: '🔒 Maintenance',
regionPrefix: 'Region',
appStoreOnly: 'App Store only',
usageTip: '⚠️ App Store only: sign in from the App Store / Media & Purchases. Do NOT sign in from Settings or iCloud. Log out immediately after download.',
},
    guides: {
      title: 'App Store Guides',
      sub: 'Practical tips, how-tos, and best practices for App Store users.',
      articles: [
        {
          title: 'How to Find the Best Apps on the App Store',
          date: '2026-05-17',
          icon: 'Search',
          sections: [
            { heading: "Start with Apple's Editorial Picks", text: "Apple's editorial team handpicks apps every week. The \"Today\" tab features in-depth stories about apps, developers, and trends. The \"Apps\" and \"Games\" tabs showcase curated collections like \"Apps We Love\" and \"New Apps We Love.\" These picks go through quality checks and are generally safer to install than random search results. Make it a habit to browse editorial collections when looking for new apps." },
            { heading: 'Read Beyond the Star Rating', text: 'Star ratings only tell part of the story. Tap into the reviews section and sort by \"Most Recent\" to see up-to-date feedback. Look for patterns: if multiple recent reviews mention the same bug, crash, or billing issue, take it seriously. Also check the version history — frequent updates usually indicate active maintenance, while apps not updated in over a year may have compatibility issues with newer iOS versions.' },
            { heading: 'Check In-App Purchase Details Before Downloading', text: 'Before tapping \"Get,\" scroll down to the \"In-App Purchases\" section on the app page. This tells you whether the app is truly free or uses a freemium model. Some apps appear free but lock core features behind paywalls. The IAP list shows what you can buy and at what price tiers. If an app lists many expensive IAPs but the description doesn\u2019t clearly explain what\u2019s free, be cautious.' },
            { heading: 'Use the Wish List Strategy', text: 'Found an interesting app but not ready to buy? Use the share sheet to add it to Notes, Reminders, or a dedicated list app. Many paid apps go on sale periodically — especially during holidays, Black Friday, or the app\u2019s anniversary. Apps like AppRaven or dedicated deal-tracking sites can notify you when wish-listed apps drop in price.' },
            { heading: 'Compare Prices Across Regions', text: 'App Store prices vary significantly by country or region due to exchange rates, taxes, and Apple\u2019s pricing tiers. An app priced at $4.99 in the US store might cost the equivalent of $3.50 in another region. Regional price comparison tools (like the Price Compare feature on this site) can help you spot savings. Keep in mind that switching App Store regions requires a valid payment method for that region.' },
          ],
        },
        { title: 'Understanding App Store Pricing and IAPs', date: '2026-05-15', icon: 'DollarSign', sections: [
          { heading: 'How Apple Sets App Prices', text: 'Apple uses a tiered pricing system that developers can choose from. Each tier maps to a price point in every currency Apple supports. When exchange rates fluctuate, Apple may adjust tier mapping, which is why you sometimes see prices change without the developer changing anything. Developers can also set custom price points for specific regions.' },
          { heading: 'Types of In-App Purchases', text: 'There are four types of IAPs: consumable (used once and gone, like game currency), non-consumable (permanent unlock, like removing ads), auto-renewable subscription (renews until canceled), and non-renewing subscription (fixed duration). Understanding which type an app uses helps you budget and avoid surprise charges.' },
          { heading: 'How to Spot Hidden Costs Before Downloading', text: 'Before downloading any free app, scroll to the \"In-App Purchases\" section on its App Store page. This lists every purchasable item with its price range. Look for patterns: an app listing 10+ IAPs ranging from $0.99 to $99.99 likely has aggressive monetization. Apps with one or two modest IAPs (like \"Remove Ads\" for $2.99) tend to be more user-friendly.' },
          { heading: 'Subscription Economics: Monthly vs. Annual', text: 'Annual subscriptions typically offer 30-50% savings compared to monthly billing. However, they lock you in for a full year. If you only need an app for a few months, monthly billing may save money despite the higher per-month rate. Always calculate your expected usage duration before choosing a plan.' },
          { heading: 'Family Sharing for IAPs and Subscriptions', text: 'Many IAPs and subscriptions support Family Sharing, allowing up to 6 family members to access the purchase at no extra cost. Check for the \"Family Sharing\" label on the App Store page. Not all apps support this — some require individual purchases per family member. When available, it can multiply the value of subscription plans.' },
        ]},
        { title: 'App Security and Privacy on iOS', date: '2026-05-14', icon: 'Shield', sections: [
          { heading: 'Understanding App Privacy Labels', text: 'Apple requires every app to disclose its data collection practices through privacy labels on the App Store. These labels are organized into three categories: Data Used to Track You (shared with other companies), Data Linked to You (tied to your identity), and Data Not Linked to You (anonymous). Always review these labels before downloading.' },
          { heading: 'App Tracking Transparency Explained', text: 'Since iOS 14.5, apps must ask permission before tracking your activity across other apps and websites. When you see the \"Ask App Not to Track\" prompt, choosing \"Ask App Not to Track\" legally prevents the app from accessing your IDFA and engaging in cross-app tracking. You can manage these permissions anytime in Settings > Privacy > Tracking.' },
          { heading: 'How to Audit App Permissions', text: 'Go to Settings > Privacy & Security to see which apps have access to your location, camera, microphone, photos, contacts, and more. Revoke permissions for apps that do not need them. iOS also shows colored dots (green for camera, orange for microphone) when apps actively use these sensors — a powerful awareness tool.' },
          { heading: 'Sign in with Apple: Why It Matters', text: 'Sign in with Apple provides a privacy-respecting alternative to email/password or social login. It creates a random relay email for each app, supports Face ID/Touch ID, and never tracks you. Apps that offer third-party login (Google, Facebook) are required to also offer Sign in with Apple. This is the safest authentication option on iOS.' },
          { heading: 'Recognizing Scam and Clone Apps', text: 'Scam apps often mimic popular apps with similar names, icons, or screenshots. Warning signs: the developer name does not match the official company, recent reviews mention subscription traps, the app has very few ratings but a high star average, or the description contains grammatical errors. Report suspicious apps using the \"Report a Problem\" link on the App Store page.' },
        ]},
        { title: 'Maximizing Free and Discounted Apps', date: '2026-05-13', icon: 'Gift', sections: [
          { heading: 'How Free App Promotions Work', text: 'Developers temporarily reduce their paid apps to free to boost rankings and attract reviews. During this window—typically 24-72 hours—if you \"purchase\" the app while it is free, it remains permanently tied to your Apple ID even after the price returns to normal. This differs from a free trial; you own the app forever.' },
          { heading: 'Where to Find Daily Free App Deals', text: 'Several communities and tools track App Store price drops: AppRaven, AppSliced, and the AppFree feature on Wolffy aggregate free promotions daily. Subreddits like r/AppHookup and r/iosgaming regularly post limited-time deals. Telegram channels dedicated to iOS deals are another excellent source for time-sensitive promotions.' },
          { heading: 'The App Store Wish List Strategy', text: 'Rather than impulse-buying, add interesting apps to a wish list using the share sheet or a dedicated app like AppRaven. These tools can notify you when prices drop. Paid apps often go on sale during holidays, Black Friday/Cyber Monday, the app\u2019s launch anniversary, or major update releases. Patience pays off—many apps are discounted 50-80% at some point.' },
          { heading: 'Free App of the Week and Apple Promotions', text: 'Historically, Apple featured a \"Free App of the Week\" promotion. While this official program ended, Apple still occasionally offers free apps and in-game items through the Apple Store app (not App Store). Check the Apple Store app\u2019s \"Stores\" tab for limited-time promotions. Apple Arcade also offers 1-3 month free trials for new subscribers.' },
          { heading: 'Understanding \"Freemium\" vs. Truly Free', text: 'A truly free app has no IAPs or advertising, which is increasingly rare. Most \"free\" apps use a freemium model—free download with paid upgrades. The key question: can you accomplish your core task without paying? For productivity apps, look for ones where the free tier provides genuine utility. For games, check if progress is gated behind paywalls in user reviews.' },
        ]},
        { title: 'How to Switch App Store Regions Safely', date: '2026-05-12', icon: 'Globe', sections: [
          { heading: 'Before You Switch: What Gets Affected', text: 'Switching your App Store region cancels all active subscriptions (Apple Music, iCloud+, third-party subscriptions), removes downloaded Apple Music tracks from your library, and makes apps unavailable if they are not in the new region\u2019s store. You must also spend any remaining Apple ID balance before switching. Download all important apps and back up your data before proceeding.' },
          { heading: 'Payment Method Requirements', text: 'To switch to a new App Store region, you must have a valid payment method issued in that country. This can be a credit/debit card, PayPal (where available), or mobile phone billing. Some regions allow \"None\" as a payment method if you have no active subscriptions and no balance. Gift cards from the target region can also be used to create a balance without a local payment method.' },
          { heading: 'Step-by-Step Region Change Process', text: '1) Sign out of Media & Purchases (Settings > [Your Name] > Media & Purchases > Sign Out). 2) Attempt to download a free app—you will be prompted to create or use an existing Apple ID. 3) Choose the target region. 4) Agree to the new terms and conditions. 5) Enter the required payment method and billing address (a valid address in the target region). 6) Complete the setup.' },
          { heading: 'Managing Multiple Apple IDs by Region', text: 'For frequent region-switchers, maintaining separate Apple IDs per region is often more practical than repeatedly switching. Use one ID for Media & Purchases (App Store, subscriptions) and another for iCloud (photos, backups, contacts). This separation lets you use apps from different regions simultaneously without losing subscriptions or data.' },
          { heading: 'Risks and Common Pitfalls', text: 'Frequent region switching can trigger Apple\u2019s fraud detection, potentially locking your account temporarily. Changes are typically limited to once every 90 days. Some apps restrict feature access based on your Apple ID region even after download. And apps removed from the new region\u2019s store will not receive updates, creating security risks over time. Use region switching sparingly and strategically.' },
        ]},
        { title: 'Complete Guide to App Store Family Sharing', date: '2026-05-11', icon: 'Users', sections: [
          { heading: 'Setting Up Family Sharing', text: 'Go to Settings > [Your Name] > Family Sharing and follow the setup prompts. One adult serves as the organizer and invites up to 5 other family members. The organizer\u2019s payment method is used for all shared purchases. Each member keeps their own Apple ID, photos, documents, and private data. Set up takes about 5 minutes and applies across all Apple devices.' },
          { heading: 'What Can Be Shared', text: 'App Store purchases, Apple subscriptions (Apple Music Family, iCloud+, Apple TV+, Apple Arcade, Apple News+, Apple Fitness+), and in-app purchases that support Family Sharing are shared automatically. Additionally, family members can share their location, a family photo album, a shared calendar, and a family reminders list. Individual iTunes Store purchases are not shared by default.' },
          { heading: 'Purchase Sharing: How It Works', text: 'When purchase sharing is enabled, all App Store purchases made by any family member are charged to the organizer\u2019s payment method. Members can download apps that any other family member has purchased at no extra cost. This applies retroactively—apps purchased before joining the family group become available to all members.' },
          { heading: 'Parental Controls: Ask to Buy', text: 'For family members under 18, the organizer can enable \"Ask to Buy,\" which sends a notification whenever the child attempts to make a purchase or download. The organizer can approve or decline directly from their device. This applies to both paid purchases and free downloads. The child cannot bypass this by signing out—the restriction is tied to their Apple ID\u2019s age.' },
          { heading: 'When Someone Leaves the Family Group', text: 'When a member leaves Family Sharing, they immediately lose access to shared subscriptions, shared iCloud storage, and apps purchased by other family members. Their own purchased apps remain. They can only join a new family group once per year. The organizer can remove members at any time, and children under 13 cannot leave a family group without being transferred to another organizer.' },
        ]},
        { title: 'App Store Refunds and Account Management', date: '2026-05-10', icon: 'DollarSign', sections: [
          { heading: 'How to Request a Refund', text: 'Go to reportaproblem.apple.com, sign in with your Apple ID, find the purchase under the \"I\u2019d like to\" dropdown, select \"Request a refund,\" choose a reason, and submit. Apple reviews each request and typically responds within 48 hours. Refunds are more likely for accidental purchases, apps that do not work as described, or unauthorized purchases by children.' },
          { heading: 'What Refunds Do Not Cover', text: 'Apple generally does not refund: purchases older than 90 days, consumable IAPs already used, subscriptions after the renewal date, or apps where you simply changed your mind. Some developers offer refunds through their own channels for cases Apple denies. Always check the developer\u2019s refund policy on their website as a secondary option.' },
          { heading: 'Apple ID Balance and Gift Cards', text: 'Your Apple ID balance can be used for App Store purchases, IAPs, subscriptions, and iCloud storage. You can add funds via credit/debit card, Apple Gift Card, or App Store & iTunes Gift Card. Balances are region-specific—a US gift card cannot be redeemed on a Chinese Apple ID. Unused balances can sometimes be transferred to another Apple ID by contacting Apple Support.' },
          { heading: 'Managing Purchase History', text: 'View your full purchase history (including free downloads) in Settings > [Your Name] > Media & Purchases > View Account > Purchase History. Filter by date range and see price, payment method, and order ID for each transaction. This is the authoritative record for any billing dispute or refund request.' },
          { heading: 'Avoiding Unauthorized Charges', text: 'Enable \"Require Password\" for purchases in Settings > Screen Time > Content & Privacy Restrictions > iTunes & App Store Purchases > Always Require. This prevents children or anyone with physical access to your device from making purchases without your password. Also regularly review your payment method and purchase history for unrecognized charges. If fraud is suspected, contact Apple Support immediately.' },
        ]},
        { title: 'How the App Store Algorithm Works', date: '2026-05-09', icon: 'Search', sections: [
          { heading: 'Search Ranking Factors', text: 'App Store search rankings are determined by a combination of relevance (keyword matches in title, subtitle, and keyword field), user behavior signals (downloads, engagement, retention), ratings and reviews (volume and recency matter more than star average), and conversion rate (impressions to downloads). Apple\u2019s algorithm also penalizes apps with high uninstall rates or frequent crashes.' },
          { heading: 'Keyword Optimization for Discovery', text: 'The App Store indexes the app title, subtitle, and a hidden 100-character keyword field. Keywords should be relevant, specific, and avoid competitor names. The title carries the most weight, followed by subtitle. Research competing apps to identify high-traffic keywords. Avoid keyword stuffing—Apple may reject updates that use irrelevant popular terms.' },
          { heading: 'The Role of Downloads and Velocity', text: 'Download velocity—the rate at which downloads occur—is a critical ranking signal. A sudden spike in downloads (from a feature, promotion, or viral moment) can boost rankings significantly. Sustained organic downloads carry more weight than bursty paid acquisition. Apple also factors in whether users keep the app installed after downloading.' },
          { heading: 'Ratings and Reviews Impact', text: 'Recent reviews influence rankings more than old ones. An app with hundreds of recent 4-star reviews may outrank one with thousands of old 5-star reviews. The written content of reviews matters—Apple\u2019s algorithm analyzes review text for sentiment and specific feature mentions. Developers can respond to reviews publicly, which may improve conversion rates.' },
          { heading: 'Regional and Category Differences', text: 'Search rankings are regional—an app may rank #1 in the US but #50 in Japan. Rankings are also category-specific. Apps listed in a less competitive category may achieve higher visibility. The \"primary category\" carries the most weight; the optional \"secondary category\" has a smaller impact. Choose categories that accurately reflect your app but also consider competitive dynamics.' },
        ]},
        { title: 'iOS Developer Account Deep Dive', date: '2026-05-08', icon: 'BookOpen', sections: [
          { heading: 'Individual vs. Organization Accounts', text: 'Individual developer accounts ($99/year) publish under your legal name. Organization accounts (also $99/year) publish under a company name and require a D-U-N-S number verification. Organization accounts can add multiple team members with role-based access (Admin, App Manager, Developer, Marketer, Finance). Choose organization if you represent a registered business.' },
          { heading: 'Apple Developer Enterprise Program', text: 'The Enterprise Program ($299/year) is for distributing proprietary internal apps to employees without using the App Store. It is strictly for in-house use and cannot be used for public distribution. Misuse (distributing to the public outside the organization) results in certificate revocation. Requires a D-U-N-S number and legal entity verification.' },
          { heading: 'TestFlight and Beta Distribution', text: 'TestFlight lets developers distribute pre-release builds to up to 10,000 external testers without App Review for initial builds. Internal testers (up to 100 team members) can access builds immediately. External builds require a one-time beta review. Builds expire after 90 days. Testers provide feedback directly through the TestFlight app.' },
          { heading: 'App Review: What to Expect', text: 'App Review checks apps against Apple\u2019s guidelines covering safety, performance, business, design, and legal requirements. Typical review time is 24-48 hours, though complex apps may take longer. Common rejection reasons include: incomplete metadata, requesting unnecessary permissions, using private APIs, misleading screenshots, or not handling IPv6 networks. Expedited reviews are available for critical bug fixes.' },
          { heading: 'Developer Account as a Credibility Signal', text: 'When browsing the App Store, check whether the developer has a developer account with a consistent history. Apps from developers with only one published app and minimal update history could indicate abandoned projects or low-effort submissions. Established developers with multiple apps and regular updates signal reliability and long-term commitment.' },
        ]},
        { title: 'How to Discover Hidden Gem Apps', date: '2026-05-07', icon: 'Star', sections: [
          { heading: 'Why Great Apps Are Not on the Charts', text: 'The App Store top charts are dominated by big-budget apps with massive marketing spend. Many excellent indie apps never reach the top 100 despite being superior in design and functionality. Discovery requires going beyond the charts: editorial collections, niche communities, curated newsletters, and word-of-mouth recommendations surface quality apps that algorithms miss.' },
          { heading: 'Curated Communities for App Discovery', text: 'Several communities specialize in surfacing quality apps: r/iosapps on Reddit, MacStories, App Store Stories, AppRaven user-curated lists, and independent blogs like The Sweet Setup. These sources prioritize design quality and utility over popularity metrics. Following 2-3 of these consistently will surface more interesting apps than browsing the App Store alone.' },
          { heading: 'Advanced Search Techniques', text: 'Use specific, functional search terms rather than broad categories. Instead of \"photo editor,\" try \"RAW photo editor with curves and batch export.\" Combine multiple relevant terms. Use the App Store\u2019s \"Works With\" collections (e.g., \"Works with Apple Watch\" or \"Works with HealthKit\") to find specialized apps. Search in English even if your store is in another language for broader results.' },
          { heading: 'Exploring International App Stores', text: 'Some of the most innovative apps debut in specific regions—Japan for creative tools, South Korea for social apps, Scandinavia for design utilities. While switching regions is complex, browsing international charts through web tools or App Store country switchers (like those on Wolffy) reveals apps not yet available in your home store but worth tracking.' },
          { heading: 'Building a Personal Discovery Workflow', text: 'Create a system: 1) Subscribe to 2-3 curated newsletters for weekly picks. 2) Use a wish list app like AppRaven to track interesting finds. 3) Set a monthly \"app audit\" to try 5 new apps and remove those you do not use. 4) Join one community discussion per week (Reddit thread, Discord server) to hear what others are using. Consistency beats intensity for discovering gems.' },
        ]},
        { title: 'Subscription Management Masterclass', date: '2026-05-06', icon: 'DollarSign', sections: [
          { heading: 'Finding All Your Active Subscriptions', text: 'Most iOS users have more active subscriptions than they realize. The primary management location is Settings > [Your Name] > Subscriptions, which shows all subscriptions billed through your Apple ID—both Apple services (iCloud+, Apple Music, Apple TV+, Apple Arcade, Apple News+, Apple Fitness+) and third-party app subscriptions. Each shows the app name, subscription tier, next renewal date, and price.' },
          { heading: 'Subscription Tiers and Upgrade/Downgrade Paths', text: 'Many apps offer multiple subscription tiers—monthly, annual, family, or premium. Annual plans are typically 30-50% cheaper than monthly but lock you in for a full year. When upgrading (e.g., Individual to Family), the remaining time on your current plan is prorated as credit. When downgrading, the lower-tier plan starts at your next renewal date—you keep current-tier access until then.' },
          { heading: 'Cancellation vs. Pausing', text: 'Apple does not offer a \"pause\" feature—you can only cancel or continue. When you cancel a subscription, you retain access for the remainder of the paid period (e.g., canceling a monthly subscription on day 5 gives you 25 more days of access). After that, the subscription expires and does not renew. There is no way to temporarily pause a subscription and resume from the same point later.' },
          { heading: 'Managing Subscriptions with Family Sharing', text: 'When part of a Family Sharing group, the organizer\u2019s subscriptions (iCloud+, Apple Music Family, Apple TV+, Apple Arcade) are automatically shared with all members. Third-party app subscriptions are generally not shared unless the developer explicitly supports Family Sharing. Each member independently manages their own third-party subscriptions.' },
          { heading: 'Avoiding Common Subscription Traps', text: '1) Free trial auto-conversion: always set a calendar reminder 2-3 days before a free trial ends. 2) Duplicate subscriptions: you might have both an individual Apple Music subscription and be in a family group paying for Apple Music Family—cancel the individual one. 3) Price increases: Apple notifies you, but notifications can be missed. 4) App deletion does not cancel subscriptions. 5) Regional pricing differences may save money.' },
        ]},
      ],
    },

    glossary: {
      title: 'App Store Glossary',
      sub: 'Essential terminology explained — 50+ terms every iOS user and developer should know.',
      terms: [
        { term: 'App Store', def: 'Apple\u2019s digital distribution platform for iOS and macOS applications. Launched in 2008, it serves over 1 billion users across 175 regions, handling app discovery, purchase, download, and update delivery.' },
        { term: 'Apple ID', def: 'Your personal Apple account used to access all Apple services including the App Store, iCloud, iMessage, and FaceTime. Each Apple ID is tied to a specific country or region that determines available content and pricing.' },
        { term: 'ASO (App Store Optimization)', def: 'The process of improving an app\u2019s visibility and conversion rate on the App Store. Key factors include app name, subtitle, keywords, description, ratings, reviews, download velocity, and engagement metrics.' },
        { term: 'Bundle ID', def: 'A unique reverse-domain identifier for each app (e.g., com.company.appname). Links the app binary to its App Store listing, entitlements, and provisioning profiles. Cannot be changed after publishing.' },
        { term: 'TestFlight', def: 'Apple\u2019s beta testing platform that lets developers distribute pre-release builds to up to 10,000 external testers. Builds expire after 90 days.' },
        { term: 'IAP (In-App Purchase)', def: 'Purchases made inside an app for digital content, subscriptions, premium features, or consumable items. Apple collects a 15-30% commission.' },
        { term: 'Provisioning Profile', def: 'A digital certificate authorizing an app to run on specific iOS devices. Links the developer certificate, App ID, and device UDIDs. Managed automatically by Xcode since 2019.' },
        { term: 'Sandbox Account', def: 'A special Apple ID for testing IAP without real money. Created in App Store Connect, sandbox accounts simulate real purchases without actual charges.' },
        { term: 'Family Sharing', def: 'Apple feature allowing up to 6 family members to share purchases, subscriptions, iCloud storage, and location while keeping separate accounts. The organizer pays for shared purchases.' },
        { term: 'App Review', def: 'Apple\u2019s mandatory review process every app must pass before App Store listing. Reviewers check against 200+ guidelines. Typical review time is 24-48 hours.' },
        { term: 'App Store Connect', def: 'The web portal developers use to manage app listings, upload builds, set pricing, view analytics, and manage TestFlight. Replaced iTunes Connect in 2018.' },
        { term: 'Price Tier', def: 'Predefined price points Apple offers for App Store pricing. Each tier maps to local currency in every region. Developers can set custom prices since 2022.' },
        { term: 'Freemium', def: 'Business model where the app is free to download but charges for premium features or ad removal through IAPs. Most top-grossing apps use this model.' },
        { term: 'Free Trial', def: 'A limited period (3-30 days) of full access before subscription billing begins. Auto-converts to paid unless canceled. One trial per Apple ID per app.' },
        { term: 'Promo Code', def: 'Alphanumeric codes developers generate to give users free/discounted IAPs or subscriptions. Limited to 100 codes per IAP.' },
        { term: 'App Thinning', def: 'Technology ensuring users download only assets needed for their device. Includes slicing, bitcode, and on-demand resources.' },
        { term: 'Universal Purchase', def: 'Single purchase granting access to an app on iPhone, iPad, Mac, Apple TV, and Apple Watch. Requires shared Bundle ID across platforms.' },
        { term: 'Privacy Label', def: 'Mandatory nutrition-style summaries on App Store pages showing data collection practices. Required since December 2020.' },
        { term: 'ATT (App Tracking Transparency)', def: 'Framework requiring apps to request permission before tracking across other apps/websites. Introduced in iOS 14.5.' },
        { term: 'Entitlements', def: 'Capabilities an app requests from the OS (Push Notifications, HealthKit, iCloud, Apple Pay). Some require App Review approval.' },
        { term: 'Keychain', def: 'Encrypted database for securely storing passwords, keys, and certificates. Data persists after app deletion.' },
        { term: 'CloudKit', def: 'Apple\u2019s cloud backend framework providing authentication, database storage, and file hosting. Generous free tiers for small-scale usage.' },
        { term: 'Game Center', def: 'Social gaming network for leaderboards, achievements, and multiplayer. Uses nickname rather than real name for privacy.' },
        { term: 'Sign in with Apple', def: 'Privacy-focused authentication providing random relay email per app. Required for apps offering third-party social login.' },
        { term: 'App Clips', def: 'Lightweight, fast app portion launched without full download. Triggered by NFC, QR codes, Safari, or Maps. 15 MB size limit.' },
        { term: 'Widget', def: 'Miniature app views on Home Screen, Lock Screen, or Today View. Built with WidgetKit using SwiftUI.' },
        { term: 'Siri Shortcuts', def: 'User-configurable automations combining app actions. Developers donate intents triggerable by voice or tap.' },
        { term: 'Dark Mode', def: 'System-wide light-on-dark color scheme since iOS 13. Uses semantic colors that adapt automatically.' },
        { term: 'Push Notifications', def: 'Remote alerts via Apple Push Notification service (APNs). Users must grant permission. Delivery is best-effort.' },
        { term: 'Offload Unused Apps', def: 'iOS storage feature that removes app binary while preserving data. Icon remains with cloud download badge.' },
        { term: 'App Store Region', def: 'Country/region tied to Apple ID determining catalog, pricing currency, and available apps. Switching cancels subscriptions.' },
        { term: 'Region Lock', def: 'When an app is available only in specific regions due to licensing, regulations, or developer choice.' },
        { term: 'Exchange Rate', def: 'Conversion rate Apple uses to adjust price tiers. Fluctuations can change prices without developer action.' },
        { term: 'Developer Account', def: 'Paid membership ($99/year) required to publish on App Store. Grants App Store Connect and TestFlight access.' },
        { term: 'Enterprise Program', def: '$299/year program for distributing internal apps to employees. Strictly for in-house use; misuse revokes certificates.' },
        { term: 'MDM (Mobile Device Management)', def: 'Technology for remotely managing iOS devices at scale. Used by businesses and schools.' },
        { term: 'App Store Review Guidelines', def: 'Comprehensive rulebook for App Store approval. Updated several times per year.' },
        { term: 'IDFA (Identifier for Advertisers)', def: 'Per-device, user-resettable identifier for ad targeting. Requires ATT permission since iOS 14.5.' },
        { term: 'IDFV (Identifier for Vendor)', def: 'Per-developer device identifier, consistent across apps from same vendor. Resets when all vendor apps deleted.' },
        { term: 'SKAdNetwork', def: 'Privacy-preserving ad attribution framework measuring conversion without tracking individuals.' },
        { term: 'App Store Server API', def: 'REST API for server-side receipt validation, subscription checks, and refund notifications.' },
        { term: 'StoreKit', def: 'Framework for IAP transactions and subscription management. StoreKit 2 uses Swift concurrency.' },
        { term: 'Xcode', def: 'Apple\u2019s IDE for building iOS, macOS, watchOS, and tvOS apps. Includes Simulator and Instruments profiler.' },
        { term: 'Swift', def: 'Apple\u2019s modern programming language introduced in 2014. Open-source, replaces Objective-C.' },
        { term: 'SwiftUI', def: 'Declarative UI framework for building interfaces across Apple platforms. State-driven, auto-updating views.' },
        { term: 'Catalyst (Mac Catalyst)', def: 'Technology for bringing iPad apps to macOS with minimal changes. Runs natively on Mac.' },
        { term: 'App Slicing', def: 'Creates device-specific app variants. Users download 30-50% smaller packages.' },
        { term: 'On-Demand Resources', def: 'Assets hosted on Apple servers, downloaded only when needed. Reduces initial download size.' },
        { term: 'Receipt Validation', def: 'Verifying IAP legitimacy via cryptographically signed Apple receipt. Prevents forgery and piracy.' },
        { term: 'Phased Release', def: 'Gradual app update rollout over 7 days. Allows monitoring crash rates before full release.' },
        { term: 'App Store Badge', def: 'Standardized download button graphic for websites and marketing. Available in multiple languages.' },
      ],
    },

    notice: {
      security: '\u26a0\ufe0f Security: Use shared accounts responsibly. Log out immediately after download to reduce risk.',
    },
    empty: 'No data',
  },
