---
import { SITE, isActive, navItems, sidebarGroups, sidebarItems } from '../astro/site.js';

const {
  title = 'Storewise - App Store research tools & safety guides',
  description = 'Independent App Store research tools: compare regional prices, estimate subscription cost, check free trials, review permissions, and read practical safety guides before you pay.',
  path = Astro.url.pathname,
  ogType = 'website',
  includeSiteSchema = true,
  robots = 'index,follow',
  // Optional trail: [{ name, item? }]. Last crumb defaults to this page canonical when item omitted.
  breadcrumbs = [],
  extraSchemas = [],
} = Astro.props;

// Always canonicalize to path without query/hash so dynamic tool searches never mint indexable URLs.
const cleanPath = String(path || '/').split('?')[0].split('#')[0] || '/';
const canonical = new URL(cleanPath, SITE).toString();
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Storewise',
  url: SITE,
  logo: `${SITE}/favicon.svg`,
  description: 'Independent bilingual App Store research site with price tools, subscription helpers, safety guides, and decision checklists.',
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Storewise',
  url: SITE,
  description,
  inLanguage: ['en', 'zh-CN'],
  publisher: { '@type': 'Organization', name: 'Storewise', url: SITE },
};

// Home-only SoftwareApplication for the free browser research tools described on-page.
// Free access only — price 0 matches the no-account, no-paywall tools on the homepage.
const softwareApplicationSchema = cleanPath === '/' ? {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Storewise',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Web',
  url: SITE,
  description,
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  publisher: { '@type': 'Organization', name: 'Storewise', url: SITE },
  inLanguage: ['en', 'zh-CN'],
} : null;

function buildBreadcrumbSchema(crumbs) {
  if (!Array.isArray(crumbs) || crumbs.length === 0) return null;
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: crumbs.map((crumb, index) => {
      const entry = {
        '@type': 'ListItem',
        position: index + 1,
        name: crumb.name,
      };
      const itemUrl = crumb.item || (index === crumbs.length - 1 ? canonical : null);
      if (itemUrl) entry.item = itemUrl;
      return entry;
    }),
  };
}

const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs);
---
<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ff6b9b" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE}/og-image.svg`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Storewise" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {includeSiteSchema && (
      <>
        <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
        {softwareApplicationSchema && (
          <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
        )}
      </>
    )}
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    {extraSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <script is:inline>
      const savedLang = localStorage.getItem('lang');
      const preferredLang = savedLang || ((navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en');
      document.documentElement.dataset.lang = preferredLang;
      document.documentElement.lang = preferredLang === 'zh' ? 'zh-CN' : 'en';
    </script>
    <link rel="stylesheet" href="/style.css" />
    <slot name="head" />
  </head>
  <body>
    <header class="top">
      <a class="brand" href="/">
        <span class="logo" aria-label="Storewise logo">S</span>
        <span class="brandText">
          <b>Storewise</b>
          <small class="lang-en">Check before you pay</small>
          <small class="lang-zh">付款前先核对</small>
        </span>
      </a>
      <nav class="toplinks" aria-label="Main navigation">
        {navItems.map((item) => (
          <a class={isActive(path, item.href) ? 'active' : ''} href={item.href}>
            <span class="lang-en">{item.label}</span>
            <span class="lang-zh">{item.labelZh}</span>
          </a>
        ))}
      </nav>
      <div class="headerActions">
        <button class="lang" type="button" data-lang-toggle aria-label="Toggle language">
          <span class="lang-en">中文</span>
          <span class="lang-zh">EN</span>
        </button>
        <button class="theme" type="button" aria-label="Toggle theme" data-theme-toggle>◐</button>
      </div>
    </header>
    <div class="shell">
      <aside class="sideNav" aria-label="Tool navigation">
        <div class="sideNavIntro">
          <span class="lang-en">App Store research</span>
          <span class="lang-zh">App Store 研究</span>
          <strong>Storewise</strong>
          <p>
            <span class="lang-en">Compare prices, review trials, and check risk signals before you pay.</span>
            <span class="lang-zh">付款前先比价、核对试用并查看风险信号。</span>
          </p>
        </div>
        {sidebarGroups.map((group) => (
          <section class="sideGroup">
            <h2>
              <span class="lang-en">{group.label}</span>
              <span class="lang-zh">{group.labelZh}</span>
            </h2>
            <div class="sideGroupItems">
              {group.items.map((item) => (
                <a class={isActive(path, item.href) ? 'active' : ''} href={item.href}>
                  <span class="sideIcon" aria-hidden="true">{item.icon}</span>
                  <span class="sideText">
                    <b>
                      <span class="lang-en">{item.label}</span>
                      <span class="lang-zh">{item.labelZh}</span>
                    </b>
                    <small>
                      <span class="lang-en">{item.desc}</span>
                      <span class="lang-zh">{item.descZh}</span>
                    </small>
                  </span>
                </a>
              ))}
            </div>
          </section>
        ))}
      </aside>
      <main id="main-content">
        <slot />
      </main>
    </div>
    <div class="mobileToolsSheet" data-tools-sheet hidden>
      <button class="mobileToolsBackdrop" type="button" data-tools-close aria-label="Close tools menu"></button>
      <div class="mobileToolsPanel" role="dialog" aria-modal="true" aria-label="Tools menu">
        <div class="mobileToolsHead">
          <div>
            <strong class="lang-en">All tools</strong>
            <strong class="lang-zh">全部工具</strong>
            <p class="lang-en">Pick a tool, then jump into the workspace.</p>
            <p class="lang-zh">选择工具后可直接进入操作区。</p>
          </div>
          <button type="button" class="mobileToolsClose" data-tools-close aria-label="Close">×</button>
        </div>
        <div class="mobileToolsList">
          {sidebarItems.map((item) => (
            <a class={isActive(path, item.href) ? 'active' : ''} href={item.href}>
              <span class="sideIcon" aria-hidden="true">{item.icon}</span>
              <span class="sideText">
                <b>
                  <span class="lang-en">{item.label}</span>
                  <span class="lang-zh">{item.labelZh}</span>
                </b>
                <small>
                  <span class="lang-en">{item.desc}</span>
                  <span class="lang-zh">{item.descZh}</span>
                </small>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
    <nav class="mobileDock" aria-label="Mobile shortcuts">
      <a class={path === '/' ? 'active' : ''} href="/">
        <span class="dockIcon">⌂</span>
        <span class="lang-en">Home</span>
        <span class="lang-zh">首页</span>
      </a>
      <button type="button" data-tools-open class={['/price','/appfree','/icon','/ip','/address','/subcost','/trial','/knowledge','/risk','/checklists','/guides','/glossary'].some((h) => isActive(path, h)) ? 'active' : ''}>
        <span class="dockIcon">◈</span>
        <span class="lang-en">Tools</span>
        <span class="lang-zh">工具</span>
      </button>
      <button type="button" data-jump-tool class="dockPrimary">
        <span class="dockIcon">◎</span>
        <span class="lang-en">Use</span>
        <span class="lang-zh">使用</span>
      </button>
      <a class={isActive(path, '/articles') ? 'active' : ''} href="/articles">
        <span class="dockIcon">☰</span>
        <span class="lang-en">Read</span>
        <span class="lang-zh">文章</span>
      </a>
      <button type="button" data-theme-toggle-mobile aria-label="Toggle theme">
        <span class="dockIcon">◐</span>
        <span class="lang-en">Theme</span>
        <span class="lang-zh">主题</span>
      </button>
    </nav>
    <footer class="siteFooter">
      <div class="footerMain">
        <div class="footerBrand">
          <span class="logo" aria-hidden="true">S</span>
          <div>
            <strong>Storewise</strong>
            <p class="lang-en">Independent App Store research tools. No account required. Always verify final prices on Apple.</p>
            <p class="lang-zh">独立 App Store 研究工具。无需注册。最终价格请以 Apple 官方页面为准。</p>
          </div>
        </div>
        <div class="footerLinks">
          <a href="/contact"><span class="lang-en">Contact</span><span class="lang-zh">联系</span></a>
          <a href="/privacy"><span class="lang-en">Privacy</span><span class="lang-zh">隐私</span></a>
          <a href="/disclaimer"><span class="lang-en">Disclaimer</span><span class="lang-zh">免责声明</span></a>
          <a href="/terms"><span class="lang-en">Terms</span><span class="lang-zh">条款</span></a>
          <a href="/editorial"><span class="lang-en">Editorial</span><span class="lang-zh">编辑原则</span></a>
          <a href="/data-sources"><span class="lang-en">Data Sources</span><span class="lang-zh">数据来源</span></a>
        </div>
      </div>
      <div class="footerMeta">Storewise © 2026</div>
    </footer>
    <script is:inline>
      const button = document.querySelector('[data-theme-toggle]');
      const mobileTheme = document.querySelector('[data-theme-toggle-mobile]');
      const langButton = document.querySelector('[data-lang-toggle]');
      const jumpButton = document.querySelector('[data-jump-tool]');
      const toolsOpen = document.querySelector('[data-tools-open]');
      const toolsSheet = document.querySelector('[data-tools-sheet]');
      const toolsClosers = document.querySelectorAll('[data-tools-close]');
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') document.body.classList.add('dark');

      function toggleTheme() {
        document.body.classList.toggle('dark');
        localStorage.setItem('theme', document.body.classList.contains('dark') ? 'dark' : 'light');
      }
      function openTools() {
        if (!toolsSheet) return;
        toolsSheet.hidden = false;
        document.body.classList.add('tools-open');
      }
      function closeTools() {
        if (!toolsSheet) return;
        toolsSheet.hidden = true;
        document.body.classList.remove('tools-open');
      }

      button?.addEventListener('click', toggleTheme);
      mobileTheme?.addEventListener('click', toggleTheme);
      langButton?.addEventListener('click', () => {
        const next = document.documentElement.dataset.lang === 'zh' ? 'en' : 'zh';
        localStorage.setItem('lang', next);
        document.documentElement.dataset.lang = next;
        document.documentElement.lang = next === 'zh' ? 'zh-CN' : 'en';
        location.reload();
      });
      jumpButton?.addEventListener('click', () => {
        closeTools();
        const target = document.querySelector('#tool-workspace, .swTool, .searchbar, .addressLayout, .ipPanel, .riskPanel, .checkToolbar, .knowledgeToolbar, .toolbar, .guideToolbar, .glossarySearch, main .card, main');
        if (target) {
          const top = target.getBoundingClientRect().top + window.scrollY - 72;
          window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
        }
      });
      toolsOpen?.addEventListener('click', openTools);
      toolsClosers.forEach((el) => el.addEventListener('click', closeTools));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeTools();
      });
    </script>
  </body>
</html>
