---
import BaseLayout from '../layouts/BaseLayout.astro';
import { toolPages } from '../astro/toolPages.js';
import PriceIsland from '../islands/PriceIsland.jsx';
import AppFreeIsland from '../islands/AppFreeIsland.jsx';
import IpIsland from '../islands/IpIsland.jsx';
import IapIsland from '../islands/IapIsland.jsx';
import IconIsland from '../islands/IconIsland.jsx';
import AddressIsland from '../islands/AddressIsland.jsx';
import GuidesIsland from '../islands/GuidesIsland.jsx';
import GlossaryIsland from '../islands/GlossaryIsland.jsx';
import ChecklistsIsland from '../islands/ChecklistsIsland.jsx';
import RiskIsland from '../islands/RiskIsland.jsx';
import KnowledgeIsland from '../islands/KnowledgeIsland.jsx';

export function getStaticPaths() {
  return Object.entries(toolPages).map(([tool, meta]) => ({
    params: { tool },
    props: { tool, meta, path: `/${tool}` },
  }));
}

const { tool, meta, path } = Astro.props;
---
<BaseLayout title={meta.title} description={meta.description} path={path}>
  {tool === 'price' && <PriceIsland client:load />}
  {tool === 'appfree' && <AppFreeIsland client:load />}
  {tool === 'ip' && <IpIsland client:load />}
  {tool === 'iap' && <IapIsland client:load />}
  {tool === 'icon' && <IconIsland client:load />}
  {tool === 'address' && <AddressIsland client:load />}
  {tool === 'guides' && <GuidesIsland client:load />}
  {tool === 'glossary' && <GlossaryIsland client:load />}
  {tool === 'checklists' && <ChecklistsIsland client:load />}
  {tool === 'risk' && <RiskIsland client:load />}
  {tool === 'knowledge' && <KnowledgeIsland client:load />}
</BaseLayout>
