---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../astro/site.js';
import { toolPages } from '../astro/toolPages.js';
import ToolStaticContent from '../components/ToolStaticContent.astro';
import PriceIsland from '../islands/PriceIsland.jsx';
import AppFreeIsland from '../islands/AppFreeIsland.jsx';
import IconIsland from '../islands/IconIsland.jsx';
import GuidesIsland from '../islands/GuidesIsland.jsx';
import GlossaryIsland from '../islands/GlossaryIsland.jsx';
import ChecklistsIsland from '../islands/ChecklistsIsland.jsx';
import RiskIsland from '../islands/RiskIsland.jsx';
import KnowledgeIsland from '../islands/KnowledgeIsland.jsx';
import SubCostIsland from '../islands/SubCostIsland.jsx';
import TrialReminderIsland from '../islands/TrialReminderIsland.jsx';

export const prerender = true;

export function getStaticPaths() {
  return Object.entries(toolPages).map(([tool, meta]) => ({
    params: { tool },
    props: { tool, meta, path: `/${tool}` },
  }));
}

const { tool, meta, path } = Astro.props;

if (tool === 'iap') {
  return Astro.redirect('/price');
}

if (tool === 'ip' || tool === 'address') {
  return Astro.redirect('/price');
}

// Content hubs also get SSR publisher blocks so crawlers see depth without JS.
// Utility tools: short intro above, interactive tool, long guide below.
const contentFirstTools = new Set(['glossary', 'checklists']);
const isContentFirst = contentFirstTools.has(tool);
const hubTools = new Set(['guides', 'knowledge', 'risk']);
const isHubTool = hubTools.has(tool);


const toolSoftwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: meta.title.replace(/ - Storewise$/, ''),
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Web',
  url: `${SITE}${path}`,
  description: meta.description,
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  publisher: { '@type': 'Organization', name: 'Storewise', url: SITE },
  isPartOf: { '@type': 'WebSite', name: 'Storewise', url: SITE },
};

const toolBreadcrumbs = [
  { name: 'Home', item: SITE },
  { name: meta.title.replace(/ - Storewise$/, ''), item: `${SITE}${path}` },
];
---
<BaseLayout
  title={meta.title}
  description={meta.description}
  path={path}
  breadcrumbs={toolBreadcrumbs}
  extraSchemas={[toolSoftwareSchema]}
>
  {!isContentFirst && <ToolStaticContent tool={tool} variant="intro" />}

  <div id="tool-workspace" class="toolWorkspace">
    {tool === 'price' && <PriceIsland client:load />}
    {tool === 'appfree' && <AppFreeIsland client:load />}
    {tool === 'icon' && <IconIsland client:load />}
    {tool === 'guides' && <GuidesIsland client:load />}
    {tool === 'glossary' && <GlossaryIsland client:load />}
    {tool === 'checklists' && <ChecklistsIsland client:load />}
    {tool === 'risk' && <RiskIsland client:load />}
    {tool === 'knowledge' && <KnowledgeIsland client:load />}
    {tool === 'subcost' && <SubCostIsland client:load />}
    {tool === 'trial' && <TrialReminderIsland client:load />}
  </div>

  {!isContentFirst && <ToolStaticContent tool={tool} variant="full" />}

  {isHubTool && (
    <section class="card toolReviewNotes" style="margin-top:1rem;" aria-label="How to use this hub">
      <div class="lang-en">
        <h2>How to use this hub</h2>
        <ol class="workflowList" style="list-style:decimal;padding-left:1.2rem;display:grid;gap:.75rem;">
          <li>
            <strong>Read the overview, then pick one path.</strong>
            <p>Use the topic sections as a map. Open one checklist or research note instead of opening five tabs at once.</p>
          </li>
          <li>
            <strong>Run a tool only after the decision criteria are clear.</strong>
            <p>Price, trial, risk, and cost tools are most useful when you already know what would make you stop.</p>
          </li>
          <li>
            <strong>Verify on official Apple screens before money moves.</strong>
            <p>Storewise is independent research. Final prices, renewals, refunds, and permissions live in App Store and Settings.</p>
          </li>
        </ol>
        <div class="contentLinks">
          <span>Related hubs</span>
          <a href="/articles">Articles</a>
          <a href="/guides">Guides</a>
          <a href="/knowledge">Knowledge</a>
          <a href="/checklists">Checklists</a>
          <a href="/privacy">Privacy</a>
        </div>
      </div>
      <div class="lang-zh" lang="zh-CN">
        <h2>如何使用本枢纽</h2>
        <ol class="workflowList" style="list-style:decimal;padding-left:1.2rem;display:grid;gap:.75rem;">
          <li>
            <strong>先读概览，再选一条路径。</strong>
            <p>把主题区块当地图。打开一份清单或研究笔记，而不是一次开五个标签页。</p>
          </li>
          <li>
            <strong>决策标准清楚后再运行工具。</strong>
            <p>比价、试用、风险与成本工具，在你已经知道“什么情况下会停止”时最有用。</p>
          </li>
          <li>
            <strong>涉及金钱前在官方 Apple 界面核验。</strong>
            <p>Storewise 是独立研究。最终价格、续费、退款与权限以 App Store 和设置为准。</p>
          </li>
        </ol>
        <div class="contentLinks">
          <span>相关枢纽</span>
          <a href="/articles">文章</a>
          <a href="/guides">指南</a>
          <a href="/knowledge">知识库</a>
          <a href="/checklists">清单</a>
          <a href="/privacy">隐私</a>
        </div>
      </div>
    </section>
  )}

  {isContentFirst && (
    <section class="card toolReviewNotes" style="margin-top:1rem;" aria-label="Reading note">
      <div class="lang-en">
        <h2>Reading note</h2>
        <p>
          This page is original educational content. Interactive sections help you apply the guidance,
          but the explanations, checklists, and definitions remain useful even when no search query is entered.
        </p>
        <div class="contentLinks">
          <span>Related reading</span>
          <a href="/articles">Articles</a>
          <a href="/checklists">Checklists</a>
          <a href="/knowledge">Knowledge base</a>
          <a href="/privacy">Privacy</a>
        </div>
      </div>
      <div class="lang-zh" lang="zh-CN">
        <h2>阅读说明</h2>
        <p>
          本页是原创教育内容。交互区域用于把说明落到操作上；即使不输入搜索关键词，
          页面中的解释、清单和定义本身也具有独立阅读价值。
        </p>
        <div class="contentLinks">
          <span>相关阅读</span>
          <a href="/articles">文章</a>
          <a href="/checklists">决策清单</a>
          <a href="/knowledge">知识库</a>
          <a href="/privacy">隐私政策</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
