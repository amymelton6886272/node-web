---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE } from '../astro/site.js';
import { articles, getArticlePath } from '../data/articles.js';

export const prerender = true;

const highlights = [
  { title: 'Compare before you pay', titleZh: '付款前先比较', text: 'Check App Store prices across regions, understand currency differences, and avoid assuming the lowest converted price is always the best purchasing choice.', textZh: '查看不同地区的 App Store 价格，理解汇率差异，不要把最低换算价格直接当成最优购买选择。' },
  { title: 'Review monetization signals', titleZh: '查看变现信号', text: 'Look up in-app purchase markers, estimate subscription cost, and use the risk assessor before starting trials or authorizing recurring billing.', textZh: '查询内购标记，估算订阅成本，在开始试用或授权自动续费前先评估风险。' },
  { title: 'Read practical safety content', titleZh: '阅读实用安全内容', text: 'Use articles, knowledge pages, checklists, privacy explanations, and family-device guidance when a simple API result is not enough.', textZh: '当单个接口结果不足以判断时，可以结合文章、知识库、清单、隐私说明和家庭设备指南一起参考。' },
  { title: 'Stay privacy aware', titleZh: '保持隐私意识', text: 'Most interactions happen in your browser. Pages explain when third-party APIs may receive your request.', textZh: '大多数交互在浏览器中完成。页面会说明哪些情况下第三方 API 可能收到你的请求。' },
];

const workflow = [
  { step: '1', title: 'Identify the app or task', titleZh: '明确应用或任务', text: 'Start with a price search, IAP lookup, subscription estimate, trial reminder, or article depending on what you need to decide.', textZh: '根据你的决策目标，从价格查询、内购查询、订阅估算、试用提醒或文章阅读开始。' },
  { step: '2', title: 'Read the context', titleZh: '阅读上下文', text: 'Each page includes explanations, limitations, data-source notes, and common mistakes so results are not interpreted in isolation.', textZh: '每个页面都包含说明、限制、数据来源和常见误区，避免把单个结果孤立解读。' },
  { step: '3', title: 'Use checklists before acting', titleZh: '行动前查看清单', text: 'Before paying, subscribing, switching regions, or installing high-permission apps, review the matching checklist or risk assessment.', textZh: '在付款、订阅、切换地区或安装高权限应用前，先查看对应清单或风险评估。' },
  { step: '4', title: 'Verify at the source', titleZh: '回到官方来源确认', text: 'For purchases, subscriptions, refunds, and availability, always confirm the final state in the App Store or Apple account settings.', textZh: '涉及购买、订阅、退款和可用性时，最终状态应以 App Store 或 Apple 账户设置为准。' },
];

const faqs = [
  {
    q: 'Is Storewise an official Apple website?',
    qZh: 'Storewise 是 Apple 官方网站吗？',
    a: 'No. Storewise is an independent App Store research site. It helps you inspect public signals and prepare safer purchase decisions, but it does not speak for Apple and cannot change Apple account outcomes.',
    aZh: '不是。Storewise 是独立的 App Store 研究站点，帮助你查看公开信号并做好更稳妥的购买准备，但不能代表 Apple，也不能改变 Apple 账号结果。',
  },
  {
    q: 'Can I treat the price comparison as the final checkout amount?',
    qZh: '价格对比结果能当作最终结算金额吗？',
    a: 'No. Regional tables and converted estimates are research signals. Taxes, account region, payment method, trials, and subscription packaging can change the amount you actually pay. Always confirm the official App Store checkout screen.',
    aZh: '不能。地区价格表和换算估值只是研究信号。税费、账号地区、付款方式、试用和订阅包装都会改变实际支付金额。请始终以官方 App Store 结算页为准。',
  },
  {
    q: 'Does deleting an app cancel a subscription?',
    qZh: '删除应用会取消订阅吗？',
    a: 'No. Cancellation lives in Settings > Apple ID > Subscriptions. Delete the app only after you confirm the plan is cancelled or set to expire if you no longer want renewals.',
    aZh: '不会。取消入口在“设置 > Apple ID > 订阅”。如果你不再需要续费，请先确认方案已取消或将到期，再删除应用。',
  },
  {
    q: 'What should I do before starting a free trial?',
    qZh: '开始免费试用前该做什么？',
    a: 'Write down the end date, renewal price, and cancellation path. Set a reminder one day early. On family devices, also check Ask to Buy and Screen Time purchase restrictions.',
    aZh: '先记下结束日期、续费价格和取消路径，并提前一天设置提醒。家庭设备还要检查“购买前询问”和屏幕使用时间中的购买限制。',
  },
  {
    q: 'Where does Storewise get its data?',
    qZh: 'Storewise 的数据从哪里来？',
    a: 'Most tools use public App Store metadata, public promotional feeds, browser-visible network information, or local generation in your browser. See the Data Sources page for limitations and verification guidance.',
    aZh: '大多数工具使用公开 App Store 元数据、公开促销源、浏览器可见网络信息，或在浏览器本地生成。限制与核验说明见“数据来源”页面。',
  },
  {
    q: 'Does Storewise require an account?',
    qZh: 'Storewise 需要注册账号吗？',
    a: 'No. You can browse guides and use basic tools without registration. Language preference and temporary UI state may be stored locally in your browser.',
    aZh: '不需要。你可以在不注册的情况下浏览指南并使用基础工具。语言偏好和临时界面状态可能会保存在浏览器本地。',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};

const latestArticles = [...articles]
  .sort((a, b) => String(b.updatedAt || b.publishedAt).localeCompare(String(a.updatedAt || a.publishedAt)))
  .slice(0, 6);

const featuredTools = [
  { href: '/price', icon: '$', label: 'Price compare', labelZh: '价格对比', desc: 'Regional App Store prices', descZh: '多地区价格对照' },
  { href: '/subcost', icon: '¥', label: 'Sub cost', labelZh: '订阅成本', desc: 'Monthly / yearly estimate', descZh: '月成本与年成本估算' },
  { href: '/trial', icon: 'D', label: 'Trial reminder', labelZh: '试用提醒', desc: 'Cancel deadline builder', descZh: '生成取消提醒与日历文案' },
  { href: '/risk', icon: '!', label: 'Risk assessor', labelZh: '风险评估', desc: 'Permission risk review', descZh: '权限与风险点自查' },
  { href: '/checklists', icon: 'C', label: 'Checklists', labelZh: '决策清单', desc: 'Before-you-act lists', descZh: '行动前检查清单' },
  { href: '/appfree', icon: 'F', label: 'Free apps', labelZh: '限免应用', desc: 'Limited-time deals', descZh: '限时免费与优惠线索' },
];

const trustLinks = [
  { href: '/data-sources', label: 'Data sources', labelZh: '数据来源' },
  { href: '/privacy', label: 'Privacy', labelZh: '隐私政策' },
  { href: '/editorial', label: 'Editorial', labelZh: '编辑原则' },
  { href: '/disclaimer', label: 'Disclaimer', labelZh: '免责声明' },
  { href: '/articles', label: 'All articles', labelZh: '全部文章' },
  { href: '/about', label: 'About', labelZh: '关于' },
];
---
<BaseLayout title="Storewise - check App Store prices, trials, and risks before you pay" description="Storewise is an independent App Store research site. Compare regional prices, estimate subscription cost, build free-trial reminders, review permission risks, and read practical safety guides before you buy." path="/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="lang-en">
    <Hero title="Decide smarter before you pay on the App Store" sub="Compare regional prices, estimate subscription cost, catch free-trial traps, and review permission risks — with practical guides next to every tool." eyebrow="App Store research" />
  </div>
  <div class="lang-zh">
    <Hero title="在 App Store 付款前，先把关键信息看清楚" sub="比较地区价格、估算订阅成本、识别试用陷阱并评估权限风险——工具旁边就有可核对的实用指南。" eyebrow="App Store 研究" />
  </div>

  <section class="homeFeatured card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Start with a tool</h2>
        <h2 class="lang-zh">先从工具开始</h2>
        <p class="lang-en">Interactive research first. Short explanations stay nearby so you can verify results before you act.</p>
        <p class="lang-zh">先做可交互研究，短说明就在旁边，方便行动前核对结果。</p>
      </div>
    </div>
    <div class="homeToolGrid">
      {featuredTools.map((tool) => (
        <a class="homeToolCard" href={tool.href}>
          <span class="homeToolIcon" aria-hidden="true">{tool.icon}</span>
          <span class="homeToolText">
            <b><span class="lang-en">{tool.label}</span><span class="lang-zh">{tool.labelZh}</span></b>
            <small><span class="lang-en">{tool.desc}</span><span class="lang-zh">{tool.descZh}</span></small>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="homeIntro card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Research tools first, empty pages never</h2>
        <h2 class="lang-zh">先给研究工具，不给空页面</h2>
        <p class="lang-en">Storewise is built for purchase decisions: price comparison, subscription cost, trial reminders, risk checks, and bilingual safety guides. Every utility page starts with a short overview, puts the interactive tool near the top, and keeps a full guide below for verification.</p>
        <p class="lang-zh">Storewise 面向购买决策：价格对比、订阅成本、试用提醒、风险检查和双语安全指南。每个工具页先给短说明，把交互工具放在上方，下方保留完整指南方便核对。</p>
      </div>
    </div>
    <div class="homeTrustLinks">
      <span class="lang-en">Trust & reading</span>
      <span class="lang-zh">信任与阅读</span>
      {trustLinks.map((link) => (
        <a href={link.href}>
          <span class="lang-en">{link.label}</span>
          <span class="lang-zh">{link.labelZh}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="richSection card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">What you can do here</h2>
        <h2 class="lang-zh">你可以在这里做什么</h2>
      </div>
    </div>
    <div class="richGrid">
      {highlights.map((item) => (
        <article class="richBlock">
          <h3 class="lang-en">{item.title}</h3>
          <h3 class="lang-zh">{item.titleZh}</h3>
          <p class="lang-en">{item.text}</p>
          <p class="lang-zh">{item.textZh}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="richSection card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Recommended workflow</h2>
        <h2 class="lang-zh">推荐使用流程</h2>
      </div>
    </div>
    <div class="workflowList">
      {workflow.map((item) => (
        <article class="workflowItem">
          <span>{item.step}</span>
          <div>
            <h3 class="lang-en">{item.title}</h3>
            <h3 class="lang-zh">{item.titleZh}</h3>
            <p class="lang-en">{item.text}</p>
            <p class="lang-zh">{item.textZh}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="richSection card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Latest articles</h2>
        <h2 class="lang-zh">最新文章</h2>
        <p class="lang-en contentLead">Practical guides on refunds, free trials, Family Sharing, permissions, region research, and subscription hygiene. These pages are written as original publisher content, not empty tool wrappers.</p>
        <p class="lang-zh contentLead">覆盖退款、免费试用、家庭共享、权限、地区研究和订阅维护的实用指南。这些页面是原创发布商内容，而不是空壳工具包装。</p>
      </div>
    </div>
    <div class="richGrid">
      {latestArticles.map((article) => (
        <a class="richBlock homeArticleCard" href={getArticlePath(article)}>
          <h3 class="lang-en">{article.title}</h3>
          <h3 class="lang-zh">{article.titleZh}</h3>
          <p class="lang-en">{article.description}</p>
          <p class="lang-zh">{article.descriptionZh}</p>
          <div class="homeArticleMeta">
            <span class="lang-en">{article.readTime} · Updated {article.updatedAt}</span>
            <span class="lang-zh">{article.readTime} · 更新于 {article.updatedAt}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="contentLinks">
      <span class="lang-en">More reading</span>
      <span class="lang-zh">更多阅读</span>
      <a href="/articles"><span class="lang-en">All articles</span><span class="lang-zh">全部文章</span></a>
      <a href="/guides"><span class="lang-en">Guides</span><span class="lang-zh">指南</span></a>
      <a href="/knowledge"><span class="lang-en">Knowledge base</span><span class="lang-zh">知识库</span></a>
      <a href="/checklists"><span class="lang-en">Checklists</span><span class="lang-zh">清单</span></a>
      <a href="/glossary"><span class="lang-en">Glossary</span><span class="lang-zh">术语表</span></a>
    </div>
  </section>

  <section class="homeFaq card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Frequently asked questions</h2>
        <h2 class="lang-zh">常见问题</h2>
      </div>
    </div>
    {faqs.map((item) => (
      <details>
        <summary>
          <span class="lang-en">{item.q}</span>
          <span class="lang-zh">{item.qZh}</span>
        </summary>
        <p class="lang-en">{item.a}</p>
        <p class="lang-zh">{item.aZh}</p>
      </details>
    ))}
  </section>

  <section class="homeWhy card">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Why Storewise exists</h2>
        <h2 class="lang-zh">为什么需要 Storewise</h2>
      </div>
    </div>
    <p class="lang-en">App Store decisions are easy to rush and hard to reverse. Regional prices differ, free trials renew quietly, subscriptions stack up, and permission prompts are easy to accept without context.</p>
    <p class="lang-en">Storewise keeps the workflow small and transparent: no account wall, no forced newsletter, no dark patterns. Tools stay near the top of the page; guides and source notes stay close enough to verify results before you act.</p>
    <p class="lang-en">Typical path: compare price → estimate subscription cost or set a trial reminder → open the matching checklist → confirm the final amount and renewal terms in the App Store.</p>
    <p class="lang-zh">App Store 决策很容易冲动，也很难撤销。地区价格不同，免费试用会静默续费，订阅会叠加，权限弹窗也容易在缺乏上下文时被点同意。</p>
    <p class="lang-zh">Storewise 刻意保持轻量和透明：没有账号墙、没有强制订阅、没有诱导式设计。工具放在页面上方，指南和数据来源说明就在旁边，方便行动前核对。</p>
    <p class="lang-zh">推荐路径：先比价 → 估算订阅成本或设置试用提醒 → 打开对应清单 → 在 App Store 确认最终金额与续费条款。</p>
  </section>
</BaseLayout>
