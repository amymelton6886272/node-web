---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { SITE } from '../../astro/site.js';
import { articles, getArticlePath } from '../../data/articles.js';
import { getRelatedArticles, getRelatedTools, getHubLinks, getArticleSeries } from '../../data/related.js';

export const prerender = true;

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const path = getArticlePath(article);
const relatedTools = getRelatedTools(article);
const relatedArticles = getRelatedArticles(article);
const hubLinks = getHubLinks();
const series = getArticleSeries(article);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.description,
  alternativeHeadline: article.titleZh,
  datePublished: article.publishedAt,
  dateModified: article.updatedAt,
  author: { '@type': 'Organization', name: 'Storewise', url: SITE },
  publisher: {
    '@type': 'Organization',
    name: 'Storewise',
    url: SITE,
    logo: { '@type': 'ImageObject', url: `${SITE}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE}${path}` },
  articleSection: article.category,
  keywords: article.tags.join(', '),
  inLanguage: ['en', 'zh-CN'],
  isPartOf: { '@type': 'WebSite', name: 'Storewise', url: SITE },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'Articles', item: `${SITE}/articles` },
    { '@type': 'ListItem', position: 3, name: article.title, item: `${SITE}${path}` },
  ],
};
---
<BaseLayout title={`${article.title} - Storewise`} description={article.description} path={path} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <div class="lang-en">
    <Hero title={article.title} sub={article.description} eyebrow={article.category} />
  </div>
  <div class="lang-zh">
    <Hero title={article.titleZh || article.title} sub={article.descriptionZh || article.description} eyebrow={article.category} />
  </div>
  <article class="articleDetail card">
    {article.titleZh && (
      <div class="articleZhIntro lang-zh" lang="zh-CN">
        <h2>{article.titleZh}</h2>
        <p>{article.descriptionZh}</p>
      </div>
    )}
    <div class="articleMeta articleMetaTop">
      <span>Updated {article.updatedAt}</span>
      <span>{article.readTime}</span>
      <span>{article.category}</span>
    </div>
    <nav class="articleToc" aria-label="Article sections">
      <strong class="lang-en">On this page</strong>
      <strong class="lang-zh">本文目录</strong>
      {article.sections.map((section, index) => <a href={`#section-${index}`}><span class="lang-en">{section.heading}</span><span class="lang-zh">{section.headingZh || section.heading}</span></a>)}
    </nav>

    {series && (
      <section class="seriesNav card" aria-label="Reading series">
        <div class="seriesNavHead">
          <div>
            <p class="seriesEyebrow lang-en">Reading series · {series.position}/{series.total}</p>
            <p class="seriesEyebrow lang-zh">阅读系列 · {series.position}/{series.total}</p>
            <h2 class="lang-en">{series.title}</h2>
            <h2 class="lang-zh">{series.titleZh}</h2>
            <p class="lang-en contentLead">{series.description}</p>
            <p class="lang-zh contentLead">{series.descriptionZh}</p>
          </div>
        </div>
        <ol class="seriesList">
          {series.items.map((item, index) => (
            <li class:list={[{ current: item.slug === article.slug }]}>
              <a href={item.href} aria-current={item.slug === article.slug ? 'page' : undefined}>
                <span class="seriesStep">{index + 1}</span>
                <span class="lang-en">{item.title}</span>
                <span class="lang-zh">{item.titleZh}</span>
              </a>
            </li>
          ))}
        </ol>
        <div class="seriesPager">
          {series.prev ? (
            <a class="seriesPagerLink prev" href={series.prev.href}>
              <span class="lang-en">Previous</span>
              <span class="lang-zh">上一篇</span>
              <strong class="lang-en">{series.prev.title}</strong>
              <strong class="lang-zh">{series.prev.titleZh}</strong>
            </a>
          ) : (
            <span class="seriesPagerLink disabled">
              <span class="lang-en">Start of series</span>
              <span class="lang-zh">系列起点</span>
            </span>
          )}
          {series.next ? (
            <a class="seriesPagerLink next" href={series.next.href}>
              <span class="lang-en">Continue</span>
              <span class="lang-zh">继续阅读</span>
              <strong class="lang-en">{series.next.title}</strong>
              <strong class="lang-zh">{series.next.titleZh}</strong>
            </a>
          ) : (
            <span class="seriesPagerLink disabled">
              <span class="lang-en">End of series</span>
              <span class="lang-zh">系列终点</span>
            </span>
          )}
        </div>
      </section>
    )}

    {article.sections.map((section, index) => (
      <section id={`section-${index}`}>
        <h2 class="lang-en">{section.heading}</h2>
        <p class="lang-en">{section.text}</p>
        {section.headingZh && <h2 class="lang-zh" lang="zh-CN">{section.headingZh}</h2>}
        {section.textZh && <p class="lang-zh" lang="zh-CN">{section.textZh}</p>}
      </section>
    ))}

    {series && series.next && (
      <section class="seriesContinue card" aria-label="Continue series">
        <p class="seriesEyebrow lang-en">Next in this series · {series.position + 1}/{series.total}</p>
        <p class="seriesEyebrow lang-zh">本系列下一篇 · {series.position + 1}/{series.total}</p>
        <h2 class="lang-en">{series.next.title}</h2>
        <h2 class="lang-zh">{series.next.titleZh}</h2>
        <p class="lang-en contentLead">Keep the same research path so related decisions stay consistent.</p>
        <p class="lang-zh contentLead">沿同一研究路径继续，相关决策会更连贯。</p>
        <div class="seriesPager">
          <a class="seriesPagerLink next" href={series.next.href}>
            <span class="lang-en">Continue reading</span>
            <span class="lang-zh">继续阅读</span>
            <strong class="lang-en">{series.next.title}</strong>
            <strong class="lang-zh">{series.next.titleZh}</strong>
          </a>
          {series.prev && (
            <a class="seriesPagerLink prev" href={series.prev.href}>
              <span class="lang-en">Previous</span>
              <span class="lang-zh">上一篇</span>
              <strong class="lang-en">{series.prev.title}</strong>
              <strong class="lang-zh">{series.prev.titleZh}</strong>
            </a>
          )}
        </div>
      </section>
    )}

    <section class="relatedBlock" aria-label="Related tools">
      <h2 class="lang-en">Related tools</h2>
      <h2 class="lang-zh">相关工具</h2>
      <p class="lang-en contentLead">Use these pages next if you need a practical check after reading this guide.</p>
      <p class="lang-zh contentLead">读完本指南后，可继续用这些页面做实际核对。</p>
      <div class="contentLinks" style="border-top:0;margin-top:0;padding-top:0;">
        {relatedTools.map((tool) => (
          <a href={tool.href}>
            <span class="lang-en">{tool.label}</span>
            <span class="lang-zh">{tool.labelZh}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="relatedBlock" aria-label="Related articles">
      <h2 class="lang-en">Related articles</h2>
      <h2 class="lang-zh">相关文章</h2>
      <div class="richGrid relatedArticleGrid">
        {relatedArticles.map((item) => (
          <a class="richBlock homeArticleCard" href={item.href}>
            <h3 class="lang-en">{item.title}</h3>
            <h3 class="lang-zh">{item.titleZh}</h3>
            <p class="lang-en">{item.description}</p>
            <p class="lang-zh">{item.descriptionZh}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="relatedBlock" aria-label="Explore more on Storewise">
      <h2 class="lang-en">Explore more on Storewise</h2>
      <h2 class="lang-zh">继续探索 Storewise</h2>
      <p class="lang-en contentLead">Jump to research hubs, practical tools, or site policies without going back to the homepage.</p>
      <p class="lang-zh contentLead">可直接进入研究枢纽、实用工具或站点政策页，无需回到首页。</p>
      <div class="contentLinks" style="border-top:0;margin-top:0;padding-top:0;">
        {hubLinks.map((link) => (
          <a href={link.href}>
            <span class="lang-en">{link.label}</span>
            <span class="lang-zh">{link.labelZh}</span>
          </a>
        ))}
      </div>
    </section>

    <div class="articleFooter">
      <a href="/articles"><span class="lang-en">All articles</span><span class="lang-zh">全部文章</span></a>
      <a href="/guides"><span class="lang-en">Guides hub</span><span class="lang-zh">指南中心</span></a>
      <a href="/checklists"><span class="lang-en">Decision checklists</span><span class="lang-zh">决策清单</span></a>
      <a href="/knowledge"><span class="lang-en">Knowledge base</span><span class="lang-zh">知识库</span></a>
      <a href="/glossary"><span class="lang-en">Glossary</span><span class="lang-zh">术语表</span></a>
      <a href="/price"><span class="lang-en">Price compare</span><span class="lang-zh">价格对比</span></a>
      <a href="/subcost"><span class="lang-en">Sub cost calculator</span><span class="lang-zh">订阅成本</span></a>
      <a href="/trial"><span class="lang-en">Trial reminder</span><span class="lang-zh">试用提醒</span></a>
      <a href="/privacy"><span class="lang-en">Privacy</span><span class="lang-zh">隐私政策</span></a>
    </div>
  </article>
</BaseLayout>
