---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { articles, getArticlePath } from '../../data/articles.js';
import { getHubLinks, getAllSeriesForIndex } from '../../data/related.js';

export const prerender = true;

const sorted = [...articles].sort((a, b) =>
  String(b.updatedAt || b.publishedAt).localeCompare(String(a.updatedAt || a.publishedAt))
);

const categories = [...new Set(sorted.map((a) => a.category).filter(Boolean))];
const hubLinks = getHubLinks();
const featured = sorted.slice(0, 6);
const seriesList = getAllSeriesForIndex();
---
<BaseLayout title="Articles - Storewise" description="Practical Apple and App Store research articles for safer purchasing, privacy, and account decisions." path="/articles">
  <Hero
    title="Articles"
    titleZh="文章"
    sub="Practical Apple and App Store research articles written for safer purchasing, privacy, and account decisions."
    subZh="围绕购买、隐私、账号和 App Store 决策的实用 Apple 研究文章。"
  />

  <section class="articleToolbar card">
    <div class="lang-en">
      <h2>Research notes before you pay</h2>
      <p>Practical Apple / App Store articles for pricing, trials, privacy labels, permissions, and account region decisions. Read alongside Storewise tools.</p>
    </div>
    <div class="lang-zh">
      <h2>付款前的研究笔记</h2>
      <p lang="zh-CN">围绕价格、试用、隐私标签、权限与账号切区的实用文章，可与 Storewise 工具一起使用。</p>
    </div>
  </section>

  <section class="relatedBlock card" aria-label="Article topics and hubs">
    <div class="homeSectionHead" style="margin-bottom:12px;">
      <div>
        <h2 class="lang-en">Topics & hubs</h2>
        <h2 class="lang-zh">主题与枢纽</h2>
        <p class="lang-en contentLead">Start from a topic cluster, or jump into tools and policy pages that support the research.</p>
        <p class="lang-zh contentLead">可从主题簇开始，或直接进入支撑研究的工具与政策页。</p>
      </div>
    </div>
    <div class="articleTags" style="margin-bottom:12px;">
      {categories.map((cat) => <span class="articleCategory">{cat}</span>)}
    </div>
    <div class="contentLinks" style="border-top:0;margin-top:0;padding-top:0;">
      {hubLinks.map((link) => (
        <a href={link.href}>
          <span class="lang-en">{link.label}</span>
          <span class="lang-zh">{link.labelZh}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="richSection card homeSeries" aria-label="Reading series">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Reading series</h2>
        <h2 class="lang-zh">阅读系列</h2>
        <p class="lang-en contentLead">Follow an ordered path instead of bouncing between isolated posts. Each series links prev/next guides for the same decision flow.</p>
        <p class="lang-zh contentLead">按顺序阅读，而不是在孤立文章之间跳转。每个系列都把同一决策流程的上一篇/下一篇串起来。</p>
      </div>
    </div>
    <div class="seriesIndexGrid">
      {seriesList.map((series) => (
        <article class="seriesIndexCard">
          <h3 class="lang-en">{series.title}</h3>
          <h3 class="lang-zh">{series.titleZh}</h3>
          <p class="lang-en">{series.description}</p>
          <p class="lang-zh">{series.descriptionZh}</p>
          <ol class="seriesList compact">
            {series.items.map((item, index) => (
              <li>
                <a href={item.href}>
                  <span class="seriesStep">{index + 1}</span>
                  <span class="lang-en">{item.title}</span>
                  <span class="lang-zh">{item.titleZh}</span>
                </a>
              </li>
            ))}
          </ol>
          <a class="homeSectionCta" href={series.startHref}>
            <span class="lang-en">Start series</span>
            <span class="lang-zh">开始本系列</span>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="richSection card homeDeepGuides" style="margin-bottom:18px;">
    <div class="homeSectionHead">
      <div>
        <h2 class="lang-en">Start here</h2>
        <h2 class="lang-zh">先从这里读</h2>
        <p class="lang-en contentLead">Recently updated guides with multi-section depth. Good entry points for Search and first-time readers.</p>
        <p class="lang-zh contentLead">近期更新的多章节指南，适合作为搜索与新读者的入口。</p>
      </div>
    </div>
    <div class="articleGrid">
      {featured.map((article) => (
        <a class="articleCard homeArticleCard" href={getArticlePath(article)}>
          <div class="articleMeta">
            <span>{article.category}</span>
            <span>{article.readTime}</span>
          </div>
          <h3 class="lang-en">{article.title}</h3>
          <h3 class="lang-zh">{article.titleZh}</h3>
          <p class="lang-en">{article.description}</p>
          <p class="lang-zh">{article.descriptionZh}</p>
          <div class="homeArticleMeta">
            <span class="lang-en">Updated {article.updatedAt}</span>
            <span class="lang-zh">更新于 {article.updatedAt}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="articleGrid">
    {sorted.map((article) => (
      <a class="articleCard card" href={getArticlePath(article)}>
        <span class="articleCategory">{article.category}</span>
        <h2 class="lang-en">{article.title}</h2>
        {article.titleZh && <h2 class="lang-zh" lang="zh-CN">{article.titleZh}</h2>}
        <p class="lang-en">{article.description}</p>
        {article.descriptionZh && <p class="lang-zh" lang="zh-CN">{article.descriptionZh}</p>}
        <div class="articleMeta">
          <span>{article.updatedAt}</span>
          <span>{article.readTime}</span>
          <span>{article.category}</span>
        </div>
        <div class="articleTags">{article.tags.map((tag) => <span>{tag}</span>)}</div>
      </a>
    ))}
  </div>
</BaseLayout>
